# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key (free at console.groq.com)
GROQ_API_KEY=gsk_...

# Tavily web search API key (free at app.tavily.com — 1000 searches/month)
TAVILY_API_KEY=tvly-...

# ── Upstash Redis (persistent storage on Vercel) ──────────────────────────────
# Copy from your Vercel project → Storage → KV → .env.local tab
# Leave blank for local development (uses local filesystem instead)

# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to 'false' to skip web search and use training data only
# USE_WEB_SEARCH=true

# Cron job secret — Vercel sets this automatically; copy to .env.local for local testing
# CRON_SECRET=your-secret-here
