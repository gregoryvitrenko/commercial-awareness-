# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key (get it at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Vercel KV (added automatically when you connect a KV store in Vercel) ─────
# Copy these from your Vercel project → Storage → KV → .env.local tab
# Leave blank for local development (uses local filesystem instead)

# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
# KV_REST_API_READ_ONLY_TOKEN=...

# ── Optional ──────────────────────────────────────────────────────────────────

# Model override (default: claude-opus-4-6)
# ANTHROPIC_MODEL=claude-opus-4-6

# Set to 'false' to skip web search and use training data only
# USE_WEB_SEARCH=true

# Cron job secret — Vercel sets this automatically; copy to .env.local for local testing
# CRON_SECRET=your-secret-here
